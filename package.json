{
  "name": "anchorage-parcel-lake",
  "version": "0.1.0",
  "private": true,
  "description": "Daily scraper for the Municipality of Anchorage property database into a published DuckDB database with full history",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@11.10.0",
  "scripts": {
    "pull": "tsx src/pull.ts",
    "ingest": "tsx src/ingest.ts",
    "audit": "tsx src/audit.ts",
    "push": "tsx src/push.ts",
    "sql": "tsx src/sql.ts",
    "app": "pnpm --dir app dev",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@duckdb/node-api": "^1.5.4-r.1",
    "aws4fetch": "^1.0.20",
    "pino": "^9.6.0",
    "tsx": "^4.19.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.10"
  }
}
