{
  "name": "anchorage-parcel-lake",
  "version": "0.1.0",
  "private": true,
  "description": "Daily scraper for the Municipality of Anchorage property database into a local DuckLake with full history",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "ingest": "tsx src/ingest.ts",
    "ingest:prod": "node --env-file=.env --import tsx src/ingest.ts",
    "dq": "vitest run test/dq.test.ts",
    "daily": "tsx src/ingest.ts && LAKE_ATTACH=ducklake:data/lake/catalog.ducklake vitest run test/dq.test.ts",
    "daily:prod": "node --env-file=.env --import tsx src/ingest.ts && LAKE_ATTACH=ducklake:data/lake-r2/catalog.ducklake vitest run test/dq.test.ts",
    "sql": "tsx src/sql.ts",
    "sql:prod": "node --env-file=.env --import tsx src/sql.ts",
    "test": "vitest run test/merge.test.ts",
    "test:girdwood": "vitest run test/girdwood.test.ts",
    "test:exemptions": "vitest run test/exemptions.test.ts",
    "test:general": "vitest run test/general.test.ts",
    "test:all": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@duckdb/node-api": "^1.5.4-r.1",
    "aws4fetch": "^1.0.20",
    "pino": "^9.6.0",
    "tsx": "^4.19.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.10"
  }
}
