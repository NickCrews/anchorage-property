# Copy to .env and fill in. The :prod npm scripts load this file; the plain
# scripts ignore it and operate on the local dev lake under data/lake.
LAKE_TARGET=r2

# Bucket name, and the account ID shown on the Cloudflare R2 overview page.
R2_BUCKET=anchorage-property
R2_ACCOUNT_ID=9d0e65e8801b8e953ee7cb4c3e840ae8

# From an R2 API token with Object Read & Write on the bucket
# (Cloudflare dashboard: R2 -> Manage API tokens).
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# Public https base URL serving the bucket: the pub-<hash>.r2.dev subdomain or
# a custom domain. Baked into the catalog on first run as the readers' data
# path — changing it later means recreating the catalog.
R2_PUBLIC_URL=https://pub-003dd855abeb48a1927aa93a77fc5471.r2.dev
