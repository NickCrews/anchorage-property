# Copy to .env and fill in. src/config.ts loads this file automatically for
# every command; real environment variables win over it. Without a .env
# everything works locally and no credentials are needed — only pull/push
# require the R2_* variables.

# Optional: which workspace (workspaces/<name>/, default "default") the verbs
# operate on. Naming the bucket-tracking workspace keeps its working copy
# separate from credential-less local experiments.
# WORKSPACE=my_experiment

# Bucket name, and the account ID shown on the Cloudflare R2 overview page.
R2_BUCKET=anchorage-property
R2_ACCOUNT_ID=9d0e65e8801b8e953ee7cb4c3e840ae8

# From an R2 API token with Object Read & Write on the bucket
# (Cloudflare dashboard: R2 -> Manage API tokens).
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# Public https base URL serving the bucket: the pub-<hash>.r2.dev subdomain or
# a custom domain. Used to log the published artifact URLs.
R2_PUBLIC_URL=https://pub-003dd855abeb48a1927aa93a77fc5471.r2.dev
